<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UI.Views.Import.CreateImportPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:UI.Utils.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="16" ColumnSpacing="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="6*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Tạo phiếu nhập mới" Style="{StaticResource TitleTextBlockStyle}" FontWeight="SemiBold"/>

        <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <AutoSuggestBox Grid.Row="0" PlaceholderText="Tìm theo tên hoặc SKU..." 
                                Text="{x:Bind ViewModel.SearchKeyword, Mode=TwoWay}"
                                QueryIcon="Find"/>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="48" Height="48" CornerRadius="4" BorderThickness="1" BorderBrush="LightGray">
                                    <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Sku}" FontSize="12" Foreground="Gray"/>
                                </StackPanel>

                                <Button Grid.Column="2" VerticalAlignment="Center" 
                                        Command="{Binding ViewModel.AddProductCommand, ElementName=RootPage}" 
                                        CommandParameter="{Binding}">
                                    <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                CornerRadius="8" Padding="16" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Padding="12,12,12,8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Sản phẩm / SKU" FontWeight="SemiBold" Foreground="Gray" FontSize="12"/>
                    <TextBlock Grid.Column="1" Text="Số lượng" FontWeight="SemiBold" Foreground="Gray" FontSize="12"/>
                    <TextBlock Grid.Column="2" Text="Giá nhập" FontWeight="SemiBold" Foreground="Gray" FontSize="12"/>
                    <TextBlock Grid.Column="3" Text="Thành tiền" FontWeight="SemiBold" Foreground="Gray" FontSize="12"/>
                </Grid>

                <Grid Grid.Row="1">

                    <ListView ItemsSource="{x:Bind ViewModel.SelectedItems, Mode=OneWay}" SelectionMode="None">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="60"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0" Spacing="2">
                                        <TextBlock Text="{Binding Name}" TextWrapping="Wrap" FontWeight="SemiBold"/>

                                        <TextBlock Text="{Binding Sku}" FontSize="12" Foreground="DarkGray"/>

                                        <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="Red" 
                               FontStyle="Italic" 
                               FontSize="12" 
                               TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <NumberBox Grid.Column="1" 
                                               IsEnabled="{Binding IsValid, Mode=OneWay}" 
                                               Value="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                               Minimum="1" SpinButtonPlacementMode="Compact" Margin="0,0,12,0" VerticalAlignment="Center"
                                               LostFocus="OnInputLostFocus"/>

                                    <NumberBox Grid.Column="2" 
                                               IsEnabled="{Binding IsValid, Mode=OneWay}"
                                               Value="{Binding ImportPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                               Minimum="0" Margin="0,0,12,0" VerticalAlignment="Center"
                                               LostFocus="OnInputLostFocus"/>

                                    <TextBlock Grid.Column="3" Text="{Binding TotalPrice, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:N0\} đ'}" 
                                               VerticalAlignment="Center" FontWeight="SemiBold"/>

                                    <Button Grid.Column="4" Background="Transparent" BorderThickness="0" Foreground="Red" VerticalAlignment="Center"
                                               ToolTipService.ToolTip="Xóa khỏi phiếu"
                                               Command="{Binding ViewModel.RemoveProductCommand, ElementName=RootPage}" 
                                               CommandParameter="{Binding}">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" 
                          Opacity="0.8"
                          Visibility="{x:Bind ViewModel.ProcessingVisibility, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsProcessingExcel, Mode=OneWay}" 
                                          Width="48" Height="48" />
                            <TextBlock Text="Đang xử lý dữ liệu Excel, vui lòng đợi..." 
                                       FontWeight="SemiBold" 
                                       Foreground="Gray"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Left">
                <FontIcon Glyph="{x:Bind ViewModel.AutoSaveIcon, Mode=OneWay}" 
                          Foreground="{x:Bind ViewModel.AutoSaveColor, Mode=OneWay}" FontSize="16"/>
                <TextBlock Text="{x:Bind ViewModel.AutoSaveText, Mode=OneWay}" 
                           Foreground="Gray" FontStyle="Italic" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Lưu phiếu tạm" Command="{x:Bind ViewModel.SaveDraftCommand}" Width="120"/>
                <Button Content="Hoàn thành" Command="{x:Bind ViewModel.CompleteImportCommand}" 
                        Style="{StaticResource AccentButtonStyle}" Width="120"/>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
