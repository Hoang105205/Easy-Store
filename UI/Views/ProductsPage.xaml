<Page
    x:Class="UI.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <FontIcon Glyph="&#xE77B;" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Danh sách sản phẩm" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox PlaceholderText="Gợi ý tìm kiếm" QueryIcon="Find" Height="40" CornerRadius="8" VerticalAlignment="Center"/>

            <ComboBox Grid.Column="1" PlaceholderText="Danh mục" Margin="15,0,0,0" Width="150" Height="40" CornerRadius="8" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="0đ" IsReadOnly="True" Margin="0,0,5,0" TextAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="950.000.000đ" IsReadOnly="True" Margin="5,0,0,0" TextAlignment="Center"/>
                </Grid>
                <Slider Minimum="0" Maximum="100" Value="100" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Column="3" Height="40" CornerRadius="8" Background="MediumPurple" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Thêm sản phẩm" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Height="40" Margin="10,0,0,0" Background="MediumPurple" CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                    <TextBlock Text="Nhập dữ liệu" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" BorderBrush="#2B88D8" BorderThickness="2" CornerRadius="16" Background="White" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Padding="10,0,10,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Tên sản phẩm" FontWeight="SemiBold" Foreground="DimGray"/>
                    <TextBlock Grid.Column="2" Text="Danh mục sản phẩm" FontWeight="SemiBold" Foreground="DimGray"/>
                    <TextBlock Grid.Column="3" Text="Số lượng tồn kho" FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Giá đơn vị" FontWeight="SemiBold" Foreground="DimGray" HorizontalAlignment="Right"/>
                </Grid>

                <ListView x:Name="ProductsListView" Grid.Row="1" SelectionMode="None" Margin="0,10,0,10">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,15,0,15" BorderBrush="#F9F9F9" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="50" Height="50" CornerRadius="8" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="Gray"/>

                                <TextBlock Grid.Column="2" Text="{Binding CategoryName}" VerticalAlignment="Center" Foreground="Gray"/>

                                <TextBlock Grid.Column="3" Text="{Binding StockQuantity}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray"/>
                                <TextBlock Grid.Column="4" Text="{Binding SalePrice}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Gray"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button x:Name="BtnPreviousPage" Style="{StaticResource TextBlockButtonStyle}" Click="BtnPreviousPage_Click" IsEnabled="False">
                        <FontIcon Glyph="&#xE76B;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                    </Button>

                    <Border Background="{ThemeResource BrandPurpleBrush}" CornerRadius="20" MinWidth="40" Height="40">
                        <TextBlock x:Name="TxtCurrentPage" Text="1" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="BtnNextPage" Style="{StaticResource TextBlockButtonStyle}" Click="BtnNextPage_Click" IsEnabled="False">
                        <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>