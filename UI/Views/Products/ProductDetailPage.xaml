<Page x:Class="UI.Views.Products.ProductDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="30">
        <StackPanel Margin="0,10,0,40">

            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE82D;" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1" VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{x:Bind ViewModel.ViewVisibility, Mode=OneWay}">
                        <Button Click="BtnEdit_Click" Style="{StaticResource AccentButtonStyle}" Background="{ThemeResource BrandPurpleBrush}" Height="40">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14"/>
                                        <TextBlock Text="Sửa sản phẩm"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Click="BtnDelete_Click" Background="#E74C3C" Foreground="White" Height="40">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                        <TextBlock Text="Xóa sản phẩm"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{x:Bind ViewModel.EditVisibility, Mode=OneWay}">
                        <Button Click="BtnSave_Click" Style="{StaticResource AccentButtonStyle}" Background="#2ECC71" Foreground="White" Height="40" FontWeight="SemiBold">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE74E;" FontSize="14"/>
                                        <TextBlock Text="Lưu thay đổi"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Click="BtnCancel_Click" Background="#E74C3C" Foreground="White" Height="40" FontWeight="SemiBold">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE711;" FontSize="14"/>
                                        <TextBlock Text="Hủy"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                </Grid>
            </Grid>

            <Grid ColumnSpacing="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="20">
                    <TextBlock Text="Hình ảnh sản phẩm" FontWeight="SemiBold" FontSize="18"/>

                    <StackPanel Visibility="{x:Bind ViewModel.ViewVisibility, Mode=OneWay}" Spacing="20" HorizontalAlignment="Center">

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Width="400" Height="400">
                            <Image Source="{x:Bind ViewModel.MainImage, Mode=OneWay}" Stretch="UniformToFill"/>
                        </Border>

                        <GridView ItemsSource="{x:Bind ViewModel.DisplayImages, Mode=OneWay}" ItemClick="Thumbnail_ItemClick" IsItemClickEnabled="True" SelectionMode="None" HorizontalAlignment="Center">
                            <GridView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="15"/>
                                </ItemsPanelTemplate>
                            </GridView.ItemsPanel>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Width="80" Height="80">
                                        <Image Source="{Binding}" Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </StackPanel>

                    <Border Visibility="{x:Bind ViewModel.EditVisibility, Mode=OneWay}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="2" CornerRadius="8" Background="{ThemeResource LayerFillColorDefaultBrush}" MinHeight="450" Padding="15" AllowDrop="True" Drop="ImageDrop" DragOver="ImageDragOver" HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="15">
                            <GridView ItemsSource="{x:Bind ViewModel.EditImages, Mode=OneWay}" SelectionMode="None" HorizontalAlignment="Center" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <GridView.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="15"/>
                                    </ItemsPanelTemplate>
                                </GridView.ItemsPanel>
                                <GridView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="90" Height="90">
                                            <Border CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                <Image Source="{Binding}" Stretch="UniformToFill"/>
                                            </Border>

                                            <Button Click="RemoveImage_Click" 
                                                    Background="#99000000" Foreground="White" 
                                                    Width="24" Height="24" Padding="0" 
                                                    CornerRadius="12" BorderThickness="0"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                    Margin="0,4,4,0" ToolTipService.ToolTip="Xóa ảnh này">
                                                <FontIcon Glyph="&#xE711;" FontSize="10"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>
                            <FontIcon x:Name="UploadIcon" Glyph="&#xEB9F;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="Kéo thả ảnh vào đây" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                            <Button Content="Tải ảnh lên" Click="UploadImages_Click" Style="{StaticResource AccentButtonStyle}" Background="{ThemeResource BrandPurpleBrush}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="20">
                    <TextBlock Text="Thông tin chi tiết" FontWeight="SemiBold" FontSize="18"/>

                    <TextBox Header="Tên sản phẩm" Text="{x:Bind ViewModel.ProductName, Mode=TwoWay}" IsReadOnly="{x:Bind ViewModel.IsReadOnly, Mode=OneWay}" Height="65"/>

                    <TextBox Header="Mã SKU" Text="{x:Bind ViewModel.Sku, Mode=TwoWay}" IsReadOnly="{x:Bind ViewModel.IsReadOnly, Mode=OneWay}" Height="65"/>

                    <ComboBox Header="Danh mục sản phẩm" ItemsSource="{x:Bind ViewModel.Categories}" SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" DisplayMemberPath="Name" IsEnabled="{x:Bind ViewModel.IsEditable, Mode=OneWay}" HorizontalAlignment="Stretch" Height="65"/>

                    <TextBox Header="Giá bán (VNĐ)" Text="{x:Bind ViewModel.SalePrice, Mode=TwoWay}" IsReadOnly="{x:Bind ViewModel.IsReadOnly, Mode=OneWay}" Height="65"/>

                    <TextBox Header="Giá nhập (VNĐ)" Text="{x:Bind ViewModel.ImportPrice, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Height="65" Background="{ThemeResource LayerFillColorDefaultBrush}"/>

                    <TextBox Header="Số lượng tồn kho" Text="{x:Bind ViewModel.StockQuantity, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Height="65" Background="{ThemeResource LayerFillColorDefaultBrush}"/>

                    <TextBox Header="ID Sản phẩm" Text="{x:Bind ViewModel.ProductId, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Height="65" Foreground="Gray"/>

                    <TextBox Header="Ngày tạo" Text="{x:Bind ViewModel.CreatedAtText, Mode=OneWay}" IsReadOnly="True" IsEnabled="False" Height="65" Foreground="Gray"/>
                </StackPanel>

            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>