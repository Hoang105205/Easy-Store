<Page
    x:Class="UI.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <FontIcon Glyph="&#xE77B;" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Danh sách sản phẩm" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox PlaceholderText="Gợi ý tìm kiếm" QueryIcon="Find" Height="40" CornerRadius="8" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="15,0,0,0" VerticalAlignment="Center">

                <ComboBox x:Name="CategoryComboBox" 
                          PlaceholderText="Danh mục" 
                          Width="150" Height="40" 
                          CornerRadius="8"
                          ItemsSource="{x:Bind CategoryVM.Categories, Mode=OneWay}"
                          DisplayMemberPath="Name" 
                          SelectionChanged="CategoryComboBox_SelectionChanged"/>

                <Button x:Name="BtnDeleteCategory" 
                        Height="40" Width="40" 
                        CornerRadius="8" 
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        IsEnabled="False"
                        ToolTipService.ToolTip="Xóa danh mục này"
                        Click="BtnDeleteCategory_Click">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E74C3C"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Margin="15,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Text="0đ" IsReadOnly="True" Margin="0,0,5,0" TextAlignment="Center"/>
                    <TextBox Grid.Column="1" Text="950.000.000đ" IsReadOnly="True" Margin="5,0,0,0" TextAlignment="Center"/>
                </Grid>
                <Slider Minimum="0" Maximum="100" Value="100" Margin="0,5,0,0"/>
            </StackPanel>

            <Button Grid.Column="3" Height="40" CornerRadius="8" Click="BtnAddProduct_Click" Background="MediumPurple" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Thêm sản phẩm" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Height="40" Margin="10,0,0,0" Background="MediumPurple" CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                    <TextBlock Text="Nhập dữ liệu" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nếu đang tải dữ liệu, hiển thị ProgressRing ở giữa -->
                <ProgressRing x:Name="LoadingRing" IsActive="{x:Bind ProductVM.IsLoading, Mode=OneWay}" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Canvas.ZIndex="10"/>

                <Grid Padding="10,0,10,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="0.25*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="Tên sản phẩm" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="SKU" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="Danh mục sản phẩm" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Grid.Column="4" Text="Số lượng tồn kho" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="Giá đơn vị" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Right"/>
                </Grid>

                <ListView x:Name="ProductsListView" ItemsSource="{x:Bind ProductVM.Products, Mode=OneWay}" Grid.Row="1" SelectionMode="None" Margin="0,10,0,10"
                          IsItemClickEnabled="True" ItemClick="ProductsListView_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,15,0,15" BorderBrush="#F9F9F9" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="125"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="0.25*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="80" Height="80" CornerRadius="8" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Sku}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding CategoryName}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{Binding StockQuantity}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="5" Text="{Binding SalePrice}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button x:Name="BtnPreviousPage" Style="{StaticResource TextBlockButtonStyle}" 
                            Click="BtnPreviousPage_Click" IsEnabled="{x:Bind ProductVM.CanGoPrevious, Mode=OneWay}">
                        <FontIcon Glyph="&#xE76B;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                    </Button>

                    <Border Background="{ThemeResource BrandPurpleBrush}" CornerRadius="20" MinWidth="40" Height="40">
                        <TextBlock x:Name="TxtCurrentPage" Text="{x:Bind ProductVM.CurrentPageNumber, Mode=OneWay}"
                                   Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Border>

                    <Button x:Name="BtnNextPage" Style="{StaticResource TextBlockButtonStyle}" 
                            Click="BtnNextPage_Click" IsEnabled="{x:Bind ProductVM.CanGoNext, Mode=OneWay}">
                        <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ContentDialog x:Name="NewCategoryDialog"
               Title="Tạo danh mục mới"
               PrimaryButtonText="Tạo mới"
               CloseButtonText="Hủy"
               DefaultButton="Primary"
               PrimaryButtonClick="NewCategoryDialog_PrimaryButtonClick">
            <StackPanel Spacing="10" Margin="0,10,0,0">
                <TextBlock Text="Vui lòng nhập tên danh mục bạn muốn tạo:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <TextBox x:Name="TxtNewCategoryName" 
                 PlaceholderText="Ví dụ: Đồ điện tử, Giày dép..." 
                 Width="300"
                 IsSpellCheckEnabled="False" 
                 IsTextPredictionEnabled="False"
                 TextChanged="TxtNewCategoryName_TextChanged"/>
                <TextBlock x:Name="TxtCategoryError" 
                   Foreground="#E74C3C" 
                   FontSize="12" 
                   Visibility="Collapsed" 
                   TextWrapping="Wrap"/>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>