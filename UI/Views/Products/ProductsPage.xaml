<Page
    x:Class="UI.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:UI.Utils.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
            <FontIcon Glyph="&#xE77B;" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Danh sách sản phẩm" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox x:Name="SearchBox"
                            Text="{x:Bind ProductVM.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Gợi ý tìm kiếm" 
                            QueryIcon="Find" 
                            Height="40" 
                            CornerRadius="8" 
                            VerticalAlignment="Center" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="15,0,0,0" VerticalAlignment="Center">
                <ComboBox x:Name="CategoryComboBox" 
                          PlaceholderText="Danh mục" 
                          Width="150" Height="40" 
                          CornerRadius="8"
                          ItemsSource="{x:Bind CategoryVM.Categories, Mode=OneWay}"
                          SelectedItem="{x:Bind CategoryVM.SelectedCategory, Mode=TwoWay}"
                          DisplayMemberPath="Name" />
                
                <Button x:Name="BtnDeleteCategory" 
                        Height="40" Width="40" 
                        CornerRadius="8" 
                        Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        IsEnabled="{x:Bind CategoryVM.Deletable, Mode=OneWay}"
                        BorderThickness="1"
                        ToolTipService.ToolTip="Xóa danh mục này"
                        Command="{x:Bind CategoryVM.DeleteSelectedCategoryCommand}">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#E74C3C"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0,15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtMinPrice" 
                             Tag="{}{0:N0} đ"
                             PlaceholderText="Từ (VNĐ)" 
                             TextAlignment="Center"
                             GotFocus="NumberTextBox_GotFocus"
                             LostFocus="NumberTextBox_LostFocus"
                             Text="{x:Bind ProductVM.MinPrice, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0} đ'}"/>

                    <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                    <TextBox x:Name="TxtMaxPrice" 
                             Tag="{}{0:N0} đ"
                             Grid.Column="2" 
                             PlaceholderText="Đến (VNĐ)" 
                             TextAlignment="Center" 
                             GotFocus="NumberTextBox_GotFocus"
                             LostFocus="NumberTextBox_LostFocus"
                             Text="{x:Bind ProductVM.MaxPrice, Mode=TwoWay, UpdateSourceTrigger=LostFocus, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0} đ'}"/>
                </Grid>
            </StackPanel>

            <Button Grid.Column="3" 
                    Height="40" CornerRadius="8" 
                    Background="MediumPurple" 
                    BorderThickness="1"
                    Command="{x:Bind ProductVM.AddProductCommand}">
                
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="Thêm sản phẩm" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Height="40" Margin="10,0,0,0" Background="MediumPurple" CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE896;" FontSize="14"/>
                    <TextBlock Text="Nhập dữ liệu" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="16" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Nếu đang tải dữ liệu, hiển thị ProgressRing ở giữa -->
                <ProgressRing x:Name="LoadingRing" IsActive="{x:Bind ProductVM.IsLoading, Mode=OneWay}" Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1" Canvas.ZIndex="10"/>

                <Grid Padding="10,0,10,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="125"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="0.25*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="1" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="0" 
                            Command="{x:Bind ProductVM.SortCommand}"
                            CommandParameter="Name">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Tên sản phẩm" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon x:Name="SortIcon_Name" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, SymbolThemeFontFamily" Glyph="{x:Bind ProductVM.SortGlyph, Mode=OneWay}" FontSize="10" 
                                        Visibility="{x:Bind ProductVM.ActiveSortColumn, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, ConverterParameter=Name}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="0" 
                            Command="{x:Bind ProductVM.SortCommand}"
                            CommandParameter="SKU">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="SKU" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon x:Name="SortIcon_SKU" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, SymbolThemeFontFamily" Glyph="{x:Bind ProductVM.SortGlyph, Mode=OneWay}" FontSize="10" 
                                        Visibility="{x:Bind ProductVM.ActiveSortColumn, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, ConverterParameter=SKU}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="3" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="0" 
                            Command="{x:Bind ProductVM.SortCommand}"
                            CommandParameter="Category">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Danh mục sản phẩm" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon x:Name="SortIcon_Category" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, SymbolThemeFontFamily" Glyph="{x:Bind ProductVM.SortGlyph, Mode=OneWay}" FontSize="10" 
                                        Visibility="{x:Bind ProductVM.ActiveSortColumn, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, ConverterParameter=Category}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="0" 
                            HorizontalAlignment="Center"
                            Command="{x:Bind ProductVM.SortCommand}"
                            CommandParameter="Quantity">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Số lượng tồn kho" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon x:Name="SortIcon_Quantity" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, SymbolThemeFontFamily" Glyph="{x:Bind ProductVM.SortGlyph, Mode=OneWay}" FontSize="10" 
                                        Visibility="{x:Bind ProductVM.ActiveSortColumn, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, ConverterParameter=Quantity}"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="5" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="0" 
                            HorizontalAlignment="Right"
                            Command="{x:Bind ProductVM.SortCommand}"
                            CommandParameter="Price">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="Giá đơn vị" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <FontIcon x:Name="SortIcon_Price" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets, SymbolThemeFontFamily" Glyph="{x:Bind ProductVM.SortGlyph, Mode=OneWay}" FontSize="10" 
                                        Visibility="{x:Bind ProductVM.ActiveSortColumn, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}, ConverterParameter=Price}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <ListView x:Name="ProductsListView" ItemsSource="{x:Bind ProductVM.Products, Mode=OneWay}" Grid.Row="1" SelectionMode="None" Margin="0,10,0,10"
                          IsItemClickEnabled="True" ItemClick="ProductsListView_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,15,0,15" BorderBrush="#F9F9F9" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="125"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="0.25*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="80" Height="80" CornerRadius="8" HorizontalAlignment="Left">
                                    <Border.Background>
                                        <ImageBrush ImageSource="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    </Border.Background>
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Sku}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="3" Text="{Binding CategoryName}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="4" Text="{Binding StockQuantity, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0}'}" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Grid.Column="5" Text="{Binding SalePrice, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0} đ'}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="{x:Bind ProductVM.DisplayRangeText, Mode=OneWay}"
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Left"
                               Foreground="Gray" 
                               FontWeight="SemiBold"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20">
                        <Button x:Name="BtnPreviousPage" 
                                Style="{StaticResource TextBlockButtonStyle}" 
                                Command="{x:Bind ProductVM.PreviousPageCommand}" 
                                IsEnabled="{x:Bind ProductVM.CanGoPrevious, Mode=OneWay}">
                            <FontIcon Glyph="&#xE76B;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                        </Button>

                        <Border Background="{ThemeResource BrandPurpleBrush}" CornerRadius="20" MinWidth="40" Height="40">
                            <TextBlock x:Name="TxtCurrentPage" 
                                       Text="{x:Bind ProductVM.CurrentPageNumber, Mode=OneWay}"
                                       Foreground="White" 
                                       VerticalAlignment="Center" HorizontalAlignment="Center" 
                                       FontWeight="Bold"/>
                        </Border>

                        <Button x:Name="BtnNextPage" 
                                Style="{StaticResource TextBlockButtonStyle}" 
                                Command="{x:Bind ProductVM.NextPageCommand}" 
                                IsEnabled="{x:Bind ProductVM.CanGoNext, Mode=OneWay}">
                            <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="{ThemeResource BrandPurpleBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>