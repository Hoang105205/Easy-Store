<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="UI.Views.Orders.OrderTabContentControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UI.Views.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:converters="using:UI.Utils.Converters"
    DataContextChanged="UserControl_DataContextChanged"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:StringFormatConverter x:Key="StringFormatConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
            <TextBlock Text="{x:Bind ViewModel.ReceiptNumber, Mode=OneWay}" FontWeight="Bold" FontSize="18"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Ngày tạo:" Foreground="Gray"/>
                <TextBlock Text="{x:Bind ViewModel.OrderDate, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0:dd/MM/yyyy HH:mm\}'}" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <controls:DataGrid x:Name="CartGrid" Grid.Row="1" Margin="0,0,0,16" AutoGenerateColumns="False" 
                           ItemsSource="{x:Bind ViewModel.CartItems, Mode=OneWay}" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <controls:DataGrid.Columns>
                <controls:DataGridTextColumn Header="STT" Binding="{Binding Stt}" IsReadOnly="True" Width="SizeToCells"/>
                <controls:DataGridTextColumn Header="Sản phẩm" Binding="{Binding ProductName}" IsReadOnly="True" Width="*"/>

                <controls:DataGridTemplateColumn Header="SL" Width="110">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <NumberBox Value="{Binding Quantity, Mode=OneWay}" 
                                           Minimum="1" 
                                           Maximum="{Binding MaxQuantity, Mode=OneWay}"
                                           ValueChanged="CartQuantity_ValueChanged"
                                           SpinButtonPlacementMode="Hidden" Width="90" Margin="4,0" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

                <controls:DataGridTextColumn Header="Đơn giá" Binding="{Binding UnitPrice, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0} đ'}" IsReadOnly="True" Width="Auto"/>

                <controls:DataGridTemplateColumn Width="60">
                    <controls:DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Background="Transparent" BorderThickness="0"
                                                Command="{Binding RemoveCommand}"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontSize="16"/>
                            </Button>
                        </DataTemplate>
                    </controls:DataGridTemplateColumn.CellTemplate>
                </controls:DataGridTemplateColumn>

            </controls:DataGrid.Columns>
        </controls:DataGrid>

        <TextBox Grid.Row="2" Header="Ghi chú" PlaceholderText="Nhập ghi chú cho đơn hàng..." 
                        Text="{x:Bind ViewModel.Note, Mode=TwoWay}" TextWrapping="Wrap" MinHeight="60" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,16" Spacing="8">
            <TextBlock Text="Tổng tiền:" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.TotalAmount, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter='{}{0:N0} đ'}" 
                       FontSize="20" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
        </StackPanel>

        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Hủy" HorizontalAlignment="Stretch" 
                            Style="{ThemeResource DefaultButtonStyle}" 
                            Command="{x:Bind ViewModel.CancelOrderCommand}"/>

            <Button Grid.Column="1" Content="Tạo đơn" HorizontalAlignment="Stretch" 
                            Style="{ThemeResource AccentButtonStyle}" 
                            Command="{x:Bind ViewModel.FinalizeOrderCommand}"/>
        </Grid>
    </Grid>
</UserControl>