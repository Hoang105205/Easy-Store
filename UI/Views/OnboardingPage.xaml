<Page
    x:Class="UI.Views.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <FlipView x:Name="OnboardingFlipView"
                      PointerPressed="OnboardingFlipView_PointerPressed"
                      PointerReleased="OnboardingFlipView_PointerReleased"
                      PointerCanceled="OnboardingFlipView_PointerCanceled">

                <FlipViewItem>
                    <Grid MaxWidth="800" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Row="0" Source="ms-appx:///Assets/onboarding1.png" MaxHeight="500" Stretch="Uniform" Margin="0,0,0,24"/>
                        <TextBlock Grid.Row="1" Text="Chào mừng đến với EasyStore!" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Grid.Row="2" Text="Giải pháp quản lý bán hàng toàn diện, giúp bạn tối ưu hóa quy trình và tăng trưởng doanh thu vượt bậc một cách dễ dàng." 
                                   FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Grid>
                </FlipViewItem>

                <FlipViewItem>
                    <Grid MaxWidth="800" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Row="0" Source="ms-appx:///Assets/onboarding1.png" MaxHeight="500" Stretch="Uniform" Margin="0,0,0,24"/>
                        <TextBlock Grid.Row="1" Text="Quản lý kho dễ dàng" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Grid.Row="2" Text="Kiểm soát số lượng tồn kho, giá nhập và giá bán chính xác đến từng chi tiết. Không còn nỗi lo thất thoát hàng hóa." 
                                   FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                    </Grid>
                </FlipViewItem>

                <FlipViewItem>
                    <Grid MaxWidth="800" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Row="0" Source="ms-appx:///Assets/onboarding1.png" MaxHeight="500" Stretch="Uniform" Margin="0,0,0,24"/>
                        <TextBlock Grid.Row="1" Text="Thống kê thông minh" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Grid.Row="2" Text="Theo dõi doanh thu, lợi nhuận và xu hướng bán hàng qua các biểu đồ trực quan, giúp bạn ra quyết định kinh doanh chuẩn xác." 
                                   FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>

                        <Button Grid.Row="3"
                                x:Name="BtnGetStarted" 
                                Content="Bắt đầu sử dụng" 
                                Click="BtnGetStarted_Click" 
                                Style="{StaticResource AccentButtonStyle}" 
                                Width="250" Height="50" 
                                CornerRadius="25" 
                                FontSize="18" FontWeight="SemiBold" 
                                HorizontalAlignment="Center" 
                                Margin="0,32,0,0"/>
                    </Grid>
                </FlipViewItem>
            </FlipView>
        </Grid>

        <PipsPager x:Name="SlidePager"
                   Grid.Row="1"
                   NumberOfPages="3" 
                   SelectedPageIndex="{x:Bind OnboardingFlipView.SelectedIndex, Mode=TwoWay}"
                   HorizontalAlignment="Center" 
                   Margin="0,20,0,10"/>
    </Grid>
</Page>