<ContentDialog
    x:Class="UI.Views.ConfigDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Cấu hình máy chủ"
    PrimaryButtonText="Lưu"
    SecondaryButtonText="Kiểm tra"
    CloseButtonText="Hủy"
    DefaultButton="Primary">

    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="{ThemeResource BrandPurpleBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{ThemeResource BrandPurpleBrush}"/>
        </Style>
    </ContentDialog.PrimaryButtonStyle>

    <StackPanel Spacing="15" Width="350">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Database URL" FontWeight="SemiBold" FontSize="14"/>
            <FontIcon Glyph="&#xE946;" FontSize="14" FontFamily="Segoe MDL2 Assets" Foreground="Gray" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBox x:Name="UrlInput" 
                 PlaceholderText="Nhập chuỗi kết nối (vd: Host=...)" 
                 TextWrapping="Wrap" 
                 AcceptsReturn="True" 
                 Height="200"
                 CornerRadius="4"/>

        <TextBlock x:Name="StatusTextBlock" FontSize="12" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>